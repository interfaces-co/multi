{
  "name": "@multi/desktop",
  "version": "0.0.17",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"pnpm run dev:bundle\" \"pnpm run dev:electron\"",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "tsdown",
    "start": "node scripts/start-electron.mjs",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "electron": "catalog:",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@multi/contracts": "workspace:*",
    "@multi/shared": "workspace:*",
    "@types/node": "catalog:",
    "concurrently": "^9.2.0",
    "tsdown": "^0.21.8",
    "typescript": "catalog:"
  },
  "productName": "Multi (Alpha)"
}
